// ============================================
// Ediora Prisma Schema
// 数据库：MySQL
// 版本：1.0
// 创建日期：2025-12-03
// ============================================
// 
// 设计原则：
// 1. 不使用外键约束（应用层维护关系）
// 2. 所有表启用软删除（deletedAt 字段）
// 3. 统一使用 String 作为主键（UUID格式）
// 4. 时间戳字段统一使用 DateTime @db.DateTime(3) 支持毫秒
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. 标签类别表 (categories)
// 用途：管理文章的分类标签，如生活、旅游、科技等
// ============================================
model Category {
  id              String    @id @default(uuid()) @db.VarChar(36)
  name            String    @db.VarChar(100)
  slug            String    @unique @db.VarChar(100)
  description     String?   @db.Text
  autoCreated     Boolean   @default(false) @map("auto_created")
  confidenceScore Decimal?  @map("confidence_score") @db.Decimal(3, 2)
  needsReview     Boolean   @default(false) @map("needs_review")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([slug], map: "idx_slug")
  @@index([deletedAt], map: "idx_deleted_at")
  @@index([autoCreated], map: "idx_auto_created")
  @@index([needsReview], map: "idx_needs_review")
  @@map("categories")
}

// ============================================
// 2. 文章标题表 (article_titles)
// 用途：管理文章标题
// ============================================
model ArticleTitle {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([slug], map: "idx_slug")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("article_titles")
}

// ============================================
// 3. 主题表 (themes)
// 用途：管理前端展示主题
// ============================================
model Theme {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean   @default(false) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([slug], map: "idx_slug")
  @@index([isActive], map: "idx_is_active")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("themes")
}

// ============================================
// 4. 域名表 (domains)
// 用途：管理域名信息（可选，发布向导也支持自定义域名）
// ============================================
model Domain {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @db.VarChar(200)
  url         String    @db.VarChar(255)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([url], map: "idx_url")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("domains")
}

// ============================================
// 5. 文章表 (articles)
// 用途：核心表，存储所有文章信息
// ============================================
enum ArticleStatus {
  draft
  published
}

model Article {
  id                String    @id @default(uuid()) @db.VarChar(36)
  title             String    @db.VarChar(500)
  slug              String    @unique @db.VarChar(500)
  content           String    @db.LongText
  excerpt           String?   @db.Text
  status            ArticleStatus @default(draft)
  
  // 关联字段（不使用外键）
  categoryId       String?   @map("category_id") @db.VarChar(36)
  titleId          String    @map("title_id") @db.VarChar(36)
  author           String    @default("Admin") @db.VarChar(100)
  
  // 发布相关字段
  publishDate      DateTime? @map("publish_date") @db.DateTime(3)
  featuredImage    String?   @map("featured_image") @db.VarChar(500)
  enableKeywordLinks Boolean @default(false) @map("enable_keyword_links")
  viewCount        Int       @default(0) @map("view_count")
  
  // SEO 元数据
  metaTitle        String?   @map("meta_title") @db.VarChar(200)
  metaDescription  String?   @map("meta_description") @db.VarChar(500)
  metaKeywords     String?   @map("meta_keywords") @db.VarChar(500)
  
  // 时间戳
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt        DateTime? @map("deleted_at") @db.DateTime(3)
  
  // 索引
  @@index([slug], map: "idx_slug")
  @@index([status], map: "idx_status")
  @@index([categoryId], map: "idx_category_id")
  @@index([titleId], map: "idx_title_id")
  @@index([publishDate], map: "idx_publish_date")
  @@index([createdAt], map: "idx_created_at")
  @@index([deletedAt], map: "idx_deleted_at")
  @@index([status, publishDate], map: "idx_status_publish_date")
  @@map("articles")
}

// ============================================
// 6. 文章标签表 (article_tags)
// 用途：存储文章的标签（多对多关系，但使用简单字符串数组方式）
// ============================================
model ArticleTag {
  id        String    @id @default(uuid()) @db.VarChar(36)
  articleId String    @map("article_id") @db.VarChar(36)
  tag       String    @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([articleId], map: "idx_article_id")
  @@index([tag], map: "idx_tag")
  @@index([deletedAt], map: "idx_deleted_at")
  @@unique([articleId, tag, deletedAt], map: "uk_article_tag")
  @@map("article_tags")
}

// ============================================
// 7. 文章自定义域名表 (article_custom_domains)
// 用途：存储文章关联的自定义域名（发布向导中添加的域名）
// ============================================
model ArticleCustomDomain {
  id        String    @id @default(uuid()) @db.VarChar(36)
  articleId String    @map("article_id") @db.VarChar(36)
  domain    String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([articleId], map: "idx_article_id")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("article_custom_domains")
}

// ============================================
// 8. 文章超链接表 (article_links)
// 用途：存储文章的超链接（发布向导中添加的关键字+URL）
// ============================================
model ArticleLink {
  id        String    @id @default(uuid()) @db.VarChar(36)
  articleId String    @map("article_id") @db.VarChar(36)
  keyword   String    @db.VarChar(200)
  url       String    @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([articleId], map: "idx_article_id")
  @@index([keyword], map: "idx_keyword")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("article_links")
}

// ============================================
// 9. 文章配图表 (article_images)
// 用途：存储文章的配图（发布向导中选择的3-5张图片）
// ============================================
model ArticleImage {
  id          String    @id @default(uuid()) @db.VarChar(36)
  articleId   String    @map("article_id") @db.VarChar(36)
  url         String    @db.VarChar(500)
  thumbnail   String?   @db.VarChar(500)
  description String?   @db.VarChar(500)
  source      String?   @db.VarChar(100)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([articleId], map: "idx_article_id")
  @@index([articleId, sortOrder], map: "idx_sort_order")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("article_images")
}

// ============================================
// 10. 资源表 (assets)
// 用途：存储媒体资源（图片、附件等，后续扩展功能）
// ============================================
model Asset {
  id        String    @id @default(uuid()) @db.VarChar(36)
  name      String    @db.VarChar(255)
  url       String    @db.VarChar(500)
  type      String    @default("image") @db.VarChar(50)
  fileSize  BigInt?   @map("file_size")
  mimeType  String?   @map("mime_type") @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([type], map: "idx_type")
  @@index([createdAt], map: "idx_created_at")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("assets")
}

// ============================================
// 11. 文章版本表 (article_versions)
// 用途：存储文章的历史版本，支持版本对比和恢复
// ============================================
model ArticleVersion {
  id        String    @id @default(uuid()) @db.VarChar(36)
  articleId String    @map("article_id") @db.VarChar(36)
  title     String    @db.VarChar(500)
  content   String    @db.LongText
  excerpt   String?   @db.Text
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([articleId], map: "idx_article_id")
  @@index([articleId, version], map: "idx_article_version")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("article_versions")
}

// ============================================
// 12. 管理员表 (admins)
// 用途：存储后台管理员账户信息
// ============================================
enum AdminRole {
  super_admin
  admin
  editor
  author
}

model Admin {
  id           String    @id @default(uuid()) @db.VarChar(36)
  username     String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  email        String?   @db.VarChar(255)
  role         AdminRole @default(editor)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)

  @@index([username], map: "idx_username")
  @@index([role], map: "idx_role")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("admins")
}
